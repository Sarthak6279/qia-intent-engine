# QIA Intent Engine — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── SERVER ───────────────────────────────────
PORT=3000
NODE_ENV=development
# Options: development | production

# ─── BLOCKCHAIN (Required for live mode) ──────
# Your RPC endpoint (Infura, Alchemy, QuickNode)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Wallet private key — without 0x prefix
# Must have testnet ETH to pay gas
PRIVATE_KEY=your_wallet_private_key_here

# Deployed QIAIncentive.sol contract address
CONTRACT_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb7

# Set to "true" to use mock blockchain (no real TX)
MOCK_BLOCKCHAIN=true

# ─── DATABASE (Production only) ───────────────
# MongoDB — for persistent API key storage
MONGODB_URI=mongodb://localhost:27017/qia

# Redis — for high-throughput caching
REDIS_URL=redis://localhost:6379

# ─── SECURITY (Production only) ───────────────
# JWT secret for admin route protection
JWT_SECRET=your_256_bit_secret_here

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=https://yourdapp.com,https://app.yourdapp.com

# Rate limit: max requests per minute per IP
RATE_LIMIT_PER_MINUTE=100

# ─── DEMO KEYS (Development only) ─────────────
# These are pre-seeded for local testing
# Remove in production
DEMO_API_KEY=qia_demo123456789
DEMO_COMPANY=demo-company
